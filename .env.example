# =============================================================================
# Nexus Gateway — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram
# Create a bot with @BotFather on Telegram.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# Virtuals Agent Compute  (Kimi K2 inference)
# Generate from your agent's Compute settings at app.virtuals.io
# -----------------------------------------------------------------------------
VIRTUALS_API_KEY=

# -----------------------------------------------------------------------------
# ACP client  (plain EOA wallet — separate from the Privy provider wallet)
# Generate a fresh wallet: npx viem generate-wallet  or use any EVM keygen tool
# This wallet needs to be registered as a Virtuals entity (ACP_CLIENT_ENTITY_ID)
# -----------------------------------------------------------------------------
ACP_CLIENT_WALLET=0x...
ACP_CLIENT_PK=0x...
ACP_CLIENT_ENTITY_ID=

# Wallet address of the running ACPLagunaTranslator provider
ACP_PROVIDER_ADDRESS=0x...

# -----------------------------------------------------------------------------
# Laguna MCP  (search, merchant info, dashboard — called directly)
# -----------------------------------------------------------------------------
LAGUNA_MCP_URL=https://agents.laguna.network/mcp

# -----------------------------------------------------------------------------
# Agoda Affiliate Long Tail Search API  (smart hotel search — see agoda-search.ts)
# Auth header format is "siteId:apiKey" — built automatically from these two.
# -----------------------------------------------------------------------------
AGODA_SITE_ID=
AGODA_API_KEY=
# Optional override — defaults to the production endpoint from the partnership docs
# AGODA_API_URL=http://affiliateapi7643.agoda.com/affiliateservice/lt_v1

# Local dev: point these at files on your machine (e.g. the repo root).
# Production (Render): these point at the persistent disk — see render.yaml.
AGODA_DB_PATH=./agoda_hotels.sqlite
AGODA_CITY_LOOKUP_PATH=./agoda_city_lookup.json

# Note: Agoda deep-link wrapping (Involve Asia) + wallet-level cashback tracking now
# happens entirely at the ACP Laguna layer (ACPLagunaTranslator's mint_link offering,
# called here via acpMintLink({ merchant_id: "agoda", target_url, wallet_address })) —
# one unified path so cashback checking/withdrawal-by-agents works the same way for
# hotels as for every other merchant. No Involve Asia credentials needed in this repo.
