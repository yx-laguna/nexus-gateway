# =============================================================================
# Nexus Gateway — Environment Variables
# Copy to .env and fill in your values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram
# Create a bot with @BotFather on Telegram.
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=

# -----------------------------------------------------------------------------
# 0G Compute Network  (DeepSeek V3 inference)
# Fund the wallet with A0GI before running.
# Testnet explorer: https://chainscan-newton.0g.ai
# -----------------------------------------------------------------------------
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
PRIVATE_KEY=0x_your_private_key_here
ZG_PROVIDER_ADDRESS=0x_provider_address_here
ZG_SERVICE_NAME=deepseek-v3

# -----------------------------------------------------------------------------
# Laguna MCP  (affiliate tools — search, mint links, dashboard)
# Each Telegram user provides their own wallet via /setwallet.
# No operator wallet needed here.
# -----------------------------------------------------------------------------
LAGUNA_MCP_URL=https://agents-dev.laguna.network/mcp
